#!/usr/bin/env bash
# Pre-commit gate. Mirrors .github/workflows/ci.yml so red CI is caught
# locally before push. Bypass with `git commit --no-verify` if you really
# need to (e.g. WIP commits on a feature branch).

set -e
cd "$(git rev-parse --show-toplevel)"

# Only run when staged changes touch Rust sources or Cargo metadata.
if ! git diff --cached --name-only | grep -qE '\.rs$|^Cargo\.(toml|lock)$'; then
  exit 0
fi

red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }

run() {
  local label="$1"; shift
  yellow "==> $label"
  if ! "$@"; then
    red   "✗ $label failed. Fix or bypass with: git commit --no-verify"
    exit 1
  fi
}

run "cargo fmt --check"            cargo fmt --check
run "cargo clippy -- -D warnings"  cargo clippy --all-targets --quiet -- -D warnings
run "cargo test"                   cargo test --quiet

green "✓ pre-commit checks passed"
